# MONGODB_TLS_SECURE_PROTOCOL=TLSv1_2_method
MONGODB_URI=mongodb+srv://aurawatterp_db_user:hilMyc6K6lTafiG6@cluster0.zmguksh.mongodb.net/?appName=Cluster0
